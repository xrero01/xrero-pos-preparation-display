<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Preparation Order Kanban View (Main Kitchen Screen) -->
    <record id="pos_preparation_order_kanban" model="ir.ui.view">
        <field name="name">pos.preparation.display.order.kanban</field>
        <field name="model">pos.preparation.display.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id"
                    class="o_kanban_small_column"
                    records_draggable="1"
                    group_create="0"
                    quick_create="0">
                <field name="stage_id"/>
                <field name="color"/>
                <field name="order_reference"/>
                <field name="product_names"/>
                <field name="note"/>
                <field name="order_date"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="#{!selection_mode ? kanban_color(record.color.raw_value) : ''} oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top mb8">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="order_reference"/>
                                        </strong>
                                    </div>
                                    <div class="o_kanban_record_top_right">
                                        <small>
                                            <field name="order_date" widget="datetime"/>
                                        </small>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="product_names"/>
                                </div>
                                <div t-if="record.note.raw_value" class="o_kanban_record_bottom mt4">
                                    <em class="text-muted">
                                        <field name="note"/>
                                    </em>
                                </div>
                                <div class="o_kanban_record_bottom mt8">
                                    <div class="oe_kanban_bottom_left"/>
                                    <div class="oe_kanban_bottom_right">
                                        <button name="action_next_stage"
                                                type="object"
                                                class="btn btn-sm btn-primary"
                                                title="Next Stage">
                                            <i class="fa fa-arrow-right"/> Next
                                        </button>
                                        <button name="action_done"
                                                type="object"
                                                class="btn btn-sm btn-success ms-1"
                                                title="Mark as Done">
                                            <i class="fa fa-check"/>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Preparation Order List View -->
    <record id="pos_preparation_order_tree" model="ir.ui.view">
        <field name="name">pos.preparation.display.order.tree</field>
        <field name="model">pos.preparation.display.order</field>
        <field name="arch" type="xml">
            <tree string="Preparation Orders">
                <field name="order_reference"/>
                <field name="display_id"/>
                <field name="stage_id"/>
                <field name="product_names"/>
                <field name="order_date"/>
                <field name="note"/>
            </tree>
        </field>
    </record>

    <!-- Preparation Order Search View -->
    <record id="pos_preparation_order_search" model="ir.ui.view">
        <field name="name">pos.preparation.display.order.search</field>
        <field name="model">pos.preparation.display.order</field>
        <field name="arch" type="xml">
            <search string="Preparation Orders">
                <field name="order_reference"/>
                <field name="display_id"/>
                <field name="stage_id"/>
                <filter name="group_by_stage" string="Stage"
                        context="{'group_by': 'stage_id'}"/>
                <filter name="group_by_display" string="Display"
                        context="{'group_by': 'display_id'}"/>
                <filter name="today" string="Today"
                        domain="[('order_date', '>=', datetime.datetime.combine(context_today(), datetime.time(0,0,0)))]"/>
            </search>
        </field>
    </record>

    <!-- Preparation Orders Action -->
    <record id="pos_preparation_order_action" model="ir.actions.act_window">
        <field name="name">Preparation Orders</field>
        <field name="res_model">pos.preparation.display.order</field>
        <field name="view_mode">kanban,tree</field>
        <field name="context">{'search_default_group_by_stage': 1, 'search_default_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No orders to prepare
            </p>
            <p>
                Orders from POS will appear here automatically when placed.
            </p>
        </field>
    </record>
</odoo>
